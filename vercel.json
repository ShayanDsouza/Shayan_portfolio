{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*",        "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/login",    "dest": "/login/index.html" },
    { "src": "/cms",      "dest": "/cms/index.html" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
